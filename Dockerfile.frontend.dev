# Dockerfile.frontend.dev
FROM node:20-bullseye

# Install small extras devs like git / curl / build tools
RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates curl git build-essential \
  && rm -rf /var/lib/apt/lists/*

# Create workspace directory and set ownership to node user
RUN mkdir -p /workspace/frontend/node_modules \
  && chown -R node:node /workspace

# Create non-root user
USER node
ENV HOME=/home/node
ENV PATH="${HOME}/.local/bin:${PATH}"
WORKDIR /workspace

# Keep a predictable npm log level and PATH
ENV NPM_CONFIG_LOGLEVEL=warn
ENV PATH=/home/node/.local/bin:$PATH

# Default behaviour: install deps and start dev server.
# You can override the CMD in docker-compose for different workflows.
CMD ["bash"]
