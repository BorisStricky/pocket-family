# DB_INSTANCE selects the database connection strategy.
# "local" (default): uses DATABASE_URL directly (standard PostgreSQL with password).
# "aws_aurora_serverless": uses IAM auth tokens via boto3 (see .env.aws.production.example).
DB_INSTANCE=local

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/pfinancedb_dev
JWT_SECRET=your-secret-key-here-generate-with-openssl-rand-hex-32
TEST_MODE=0

# AUTO_CREATE_SCHEMA=1 builds the DB schema from the SQLModel models on app startup
# (local dev convenience). Leave 0 to rehearse the production flow where Alembic owns
# the schema; every non-dev environment keeps this 0 so create_all never races migrations.
AUTO_CREATE_SCHEMA=1

# Set DEMO_MODE=1 locally to exercise the public-demo lockdowns (disabled
# signup, seeded demo user, etc.). The matching frontend flag below must
# also be set so the UI matches the API behaviour.
DEMO_MODE=0

# Frontend (Vite requires VITE_ prefix)
VITE_API_URL=/api
VITE_DEMO_MODE=false
# Optional: Test user credentials for development auto-fill
# VITE_TEST_USER_EMAIL=test@example.com
# VITE_TEST_USER_PASSWORD=test123
# VITE_TEST_USER_NAME=Test User
