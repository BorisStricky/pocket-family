{
  "model": "Sonnet",
  "enabledPlugins": {
    "obsidian@obsidian-skills": true,
    "frontend-design@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Agent",
      "WebFetch",
      "WebSearch"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": []
    },
    "filesystem": {
      "denyRead": ["~/"],
      "allowRead": ["."]
    }
  }
}
