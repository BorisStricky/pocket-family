# .env.production.example
# Copy this file to .env.production and fill in real values before deploying.
#
# For local docker-compose:
#   docker-compose --env-file .env.production up --build
#
# For AWS Fargate: values are injected as environment variables in the ECS task definition.
# See aws/ecs-task-definition.json for the task definition template.
#
# NEVER commit .env.production to source control.

# ── RDS PostgreSQL connection ─────────────────────────────────────────────────
# DB_HOST: the RDS endpoint — shown in the RDS console after the instance is created.
# Looks like: pocket-family-db.xxxxxxxxxx.us-east-1.rds.amazonaws.com
DB_HOST=your-rds-instance.xxxxxxxxxx.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_me_strong_password
DB_NAME=pfinancedb

# ── JWT signing secret ────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_me_with_output_of_openssl_rand_hex_32

# ── CORS origins ──────────────────────────────────────────────────────────────
# Set to the public URL users will use to reach the frontend.
# For Fargate behind an ALB: use the ALB DNS name or your custom domain.
#   CORS_ORIGINS=https://pocket-family.example.com
# For raw EC2 with docker-compose on port 3000:
#   CORS_ORIGINS=http://1.2.3.4:3000
CORS_ORIGINS=https://your-alb-or-domain.example.com

# ── Frontend API URL (build-time, baked into the JS bundle by Vite) ───────────
# Keep as /api — nginx proxies /api/ requests to the backend.
# Do not change this unless you also change the nginx proxy rule.
VITE_API_URL=/api
