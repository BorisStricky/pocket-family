# .env.production.example
# Copy this file to .env.production and fill in real values before deploying.
# Usage: docker-compose --env-file .env.production up --build
#
# NEVER commit .env.production to source control.

# Postgres password — must match POSTGRES_PASSWORD inside the db service
DB_PASSWORD=change_me_strong_password

# Secret key used to sign JWT tokens.
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_me_with_output_of_openssl_rand_hex_32
