# .env.aws.production.example
# Copy this file to .env.aws.production and fill in real values before deploying.
#
# For AWS Fargate: values are injected as environment variables in the ECS task definition.
# See aws/ecs-task-definition.json for the task definition template.
#
# NEVER commit .env.aws.production to source control.

# ── Database connection strategy ────────────────────────────────────────────
# "aws_aurora_serverless" uses IAM database authentication via boto3.
# No static password needed — the backend generates short-lived IAM tokens automatically.
DB_INSTANCE=aws_aurora_serverless

# ── Aurora Serverless v2 connection ─────────────────────────────────────────
# DB_HOST: the Aurora cluster writer endpoint (shown in the RDS console).
# Looks like: pocket-family-db.cluster-xxxxxxxxxx.us-east-1.rds.amazonaws.com
DB_HOST=pocket-family-db.cluster-xxxxxxxxxx.us-east-1.rds.amazonaws.com
DB_PORT=5432
# DB_USER: the PostgreSQL user mapped to IAM auth (NOT the master/admin user).
# You must create this user in the database and grant it the rds_iam role:
#   CREATE USER iam_app_user;
#   GRANT rds_iam TO iam_app_user;
#   GRANT ALL PRIVILEGES ON ALL TABLES IN SCHEMA public TO iam_app_user;
DB_USER=iam_app_user
DB_NAME=pfinancedb
AWS_REGION=us-east-1

# ── JWT signing secret ────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_me_with_output_of_openssl_rand_hex_32

# ── App settings ──────────────────────────────────────────────────────────────
TEST_MODE=0

# ── Demo instance (public showcase only) ──────────────────────────────────────
# Set to 1 to turn this deployment into the public demo:
#   * /auth/signup, tenant deletion, invites and member-management endpoints
#     return 403.
#   * Backend ensures demo@pocket-family.com exists at startup.
#   * Pair with VITE_DEMO_MODE=true on the frontend build (passed via
#     build-and-push.sh DEMO_MODE=1) and -var="demo_mode=true" on terraform
#     apply to provision the daily EventBridge reset.
DEMO_MODE=0

# ── CORS origins ──────────────────────────────────────────────────────────────
# Set to the public URL users will use to reach the frontend.
# For Fargate behind an ALB: use the ALB DNS name or your custom domain.
CORS_ORIGINS=https://your-alb-or-domain.example.com

# ── Frontend API URL (build-time, baked into the JS bundle by Vite) ───────────
# Keep as /api — nginx proxies /api/ requests to the backend.
VITE_API_URL=/api

# Build-time toggle for the demo frontend. Must match the backend DEMO_MODE
# value above so the UI lockdowns line up with the server-side 403s. Passed
# through to the Docker build via build-and-push.sh DEMO_MODE=1.
VITE_DEMO_MODE=false
