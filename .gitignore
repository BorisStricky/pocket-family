# Personal files
personal/

# Environment files (sensitive data)
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/

#node modules#
node_modules/*

#agentic_qe
.agentic-qe
.claude
Agentic QCSD/*
# Backup of CLAUDE.md created by Agentic QE init — machine-local, not for the repo
CLAUDE.md.backup
# Root-level node project from Agentic QE init (leading slash anchors to repo
# root only, so frontend/package.json stays tracked)
/package.json
/package-lock.json

# Frontend
frontend/node_modules
frontend/.vite/
frontend/dist
frontend/coverage/

# Logs
*.log

# Local dev uploads (created by infrastructure/dev.sh — shared between API and worker)
.dev-uploads/

# IDE
.vscode/settings.json
.idea/

# Dotfiles that belong in ~ not in the repo
.bash_profile
.bashrc
.profile
.zprofile
.zshrc
.gitconfig
.gitmodules
.mcp.json
.ripgreprc

# Obsidian config
.obsidian

# Note: .env.example files are intentionally not ignored - they should be committed
.claude/settings.local.json
.claude/worktrees/
# Claude memory is machine-local (canonical store lives outside the repo under
# ~/.claude/projects/.../memory/); ignore any in-repo copy so it's never committed
.claude/memory/
.env.aws.production

# Terraform — secrets and local state
infrastructure/terraform/terraform.tfvars
infrastructure/terraform/*.tfstate
infrastructure/terraform/*.tfstate.backup
infrastructure/terraform/.terraform/
infrastructure/terraform/.terraform.lock.hcl
